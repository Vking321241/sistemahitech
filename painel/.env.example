# ── Painel TechOS — variaveis de ambiente (defina no EasyPanel) ──

# Login unico de admin
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-forte
# Segredo pra assinar o cookie de sessao (gere: openssl rand -hex 24)
SESSION_SECRET=

# Segredo compartilhado com o n8n (autentica /api/enroll/*). Gere outro hex.
N8N_SECRET=

# Onde ficam os dados (volume persistente do EasyPanel)
DATA_DIR=/data

# ── Tunel / dominio ──
DOMINIO_BASE=divary.shop
TUNEL_SERVIDOR=tunel.divary.shop
TUNEL_PORTA=7000
# O MESMO token do frps.toml da VPS
TUNEL_TOKEN=
# Porta HTTP interna do frps (target dos dominios)
FRPS_VHOST_PORT=8080

# ── EasyPanel API (opcional — se em branco, cai no modo manual) ──
# URL do seu EasyPanel (normalmente porta 3000)
EASYPANEL_URL=https://painel.divary.shop:3000
# Token permanente da API (users.generateApiToken) ou de sessao (auth.login)
EASYPANEL_TOKEN=
# Nome do projeto e do servico frps no EasyPanel
EASYPANEL_PROJECT=
EASYPANEL_SERVICE=frps
# Procedimento tRPC de criar dominio (ajuste se sua versao usar outro nome)
EASYPANEL_CREATE_DOMAIN_PROC=services.app.createDomain
